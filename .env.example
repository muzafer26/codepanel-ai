# ⌬ CODEPANEL // AI — Environment Variables Template
# Copy this file to '.env.local' and populate with your credentials.
# Do NOT commit '.env.local' to source control.

# --- LLM API Keys ---
# The server will automatically detect and route to Groq if the key starts with 'gsk_',
# or Google Generative AI SDK otherwise.
# You need at least one of the following configured.

# Groq API Key (https://console.groq.com/)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini API Key (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
